# .env.example — StreamVex Live
# এই ফাইলটা copy করো → .env.local নামে রাখো → values দাও
# কমান্ড: cp .env.example .env.local
#
# ⚠️  .env.local কখনো GitHub এ push করবে না — .gitignore এ আছে
# ✅  Vercel এ deploy করতে: Vercel Dashboard → Project → Settings → Environment Variables

# ── CricAPI (cricket live scores, series info) ────────
# সাইট: https://cricapi.com → Free account → API key নাও
# Free tier: 100 calls/day
CRICAPI_KEY=your_cricapi_key_here

# ── RapidAPI (cricket fixtures, football live scores) ──
# সাইট: https://rapidapi.com → Account → App → Key
# Subscriptions দরকার:
#   cricket-live-line1 → Free plan (100 req/day)
#   allsportsapi2      → Free plan
RAPIDAPI_KEY=your_rapidapi_key_here

# ── football-data.org (standings, results, fixtures) ───
# সাইট: https://www.football-data.org → Register → Free tier
# Free tier: 10 req/min, major leagues
FOOTBALL_DATA_API_KEY=your_football_data_key_here

# ── Groq AI (AI Match Analyst chat) ───────────────────
# সাইট: https://console.groq.com → API Keys → Create
# Free tier: খুবই generous (70B model, fast inference)
GROQ_API_KEY=your_groq_api_key_here

# ── Vercel KV (server-side caching) ───────────────────
# Vercel Dashboard → Storage → Create KV Database
# .env.local এ paste করো (Vercel auto-generate করে)
KV_URL=your_kv_url_here
KV_REST_API_URL=your_kv_rest_api_url_here
KV_REST_API_TOKEN=your_kv_rest_api_token_here
KV_REST_API_READ_ONLY_TOKEN=your_kv_read_only_token_here

# ── CORS (API security) ────────────────────────────────
# Production domain — API routes শুধু এই origin থেকে accept করবে
# Local dev: http://localhost:5173
ALLOWED_ORIGIN=https://streamvex.live

# ── Cloudflare Worker URL (CORS stream proxy) ──────────
# wrangler deploy করার পরে URL পাবে
# Format: https://streamvex-cors-proxy.YOUR_SUBDOMAIN.workers.dev
VITE_WORKER_URL=https://streamvex-cors-proxy.your-subdomain.workers.dev

# ── Dev helpers ───────────────────────────────────────
# VITE_SKIP_PROXY=true করলে dev-এ direct stream URL use করবে (proxy bypass)
# Production এ এটা false বা unset রাখো
VITE_SKIP_PROXY=false

# ── Optional: proxy base URL override ─────────────────
# Default: VITE_WORKER_URL ব্যবহার করে
# শুধু custom proxy setup থাকলে দাও
# VITE_PROXY_BASE_URL=https://your-custom-proxy.com
